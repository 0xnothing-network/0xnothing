# === 0xPixel Frontend — Environment Variables ===
# Copy this file to .env.local and fill in your values

# Alchemy API URL for Ethereum mainnet RPC
# Get free at https://www.alchemy.com/ (create app → API Key → Copy HTTP)
NEXT_PUBLIC_ALCHEMY_API_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Deployed contract address — fill after running deploy script
NEXT_PUBLIC_CONTRACT_ADDRESS=0x6F70ac7185133002EC209EE55f83A00A7fC9C7c6

# WalletConnect Project ID — required for mobile wallet connections
# Get free at https://cloud.walletconnect.com (create project → copy Project ID)
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your_walletconnect_project_id_here
